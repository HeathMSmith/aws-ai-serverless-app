{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TerraformCoreServices",
      "Effect": "Allow",
      "Action": [
        "s3:*",
        "dynamodb:*",
        "lambda:*",
        "apigateway:*",
        "logs:*",

        "iam:CreateRole",
        "iam:DeleteRole",
        "iam:GetRole",
        "iam:ListRoles",

        "iam:PassRole",

        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:ListAttachedRolePolicies",

        "iam:PutRolePolicy",
        "iam:GetRolePolicy",
        "iam:DeleteRolePolicy",
        "iam:ListRolePolicies",

        "iam:GetPolicy",
        "iam:ListPolicies",
        "iam:GetPolicyVersion",

        "bedrock:InvokeModel"
      ],
      "Resource": "*"
    }
  ]
}